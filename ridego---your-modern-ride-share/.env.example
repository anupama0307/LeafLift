# ─── OLA Maps API ───────────────────────────────────────
VITE_OLA_MAPS_API_KEY=your_ola_maps_api_key_here
VITE_OLA_PROJECT_ID=your_ola_project_id_here
OLA_MAPS_API_KEY=your_ola_maps_api_key_here

# ─── Firebase (Client-Side) ────────────────────────────
VITE_FIREBASE_API_KEY=your_firebase_api_key
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789
VITE_FIREBASE_APP_ID=1:123456789:web:abcdef

# ─── MongoDB ────────────────────────────────────────────
MONGODB_URI=mongodb://localhost:27017/leaflift

# ─── Main Server ────────────────────────────────────────
PORT=5001
CORS_ORIGIN=http://localhost:3005

# ─── Admin Server ───────────────────────────────────────
ADMIN_PORT=5002
MAIN_SERVER_URL=http://localhost:5001

# ─── Email OTP (Gmail) ─────────────────────────────────
OTP_EMAIL_USER=your_email@gmail.com
OTP_EMAIL_PASS=your_app_password
